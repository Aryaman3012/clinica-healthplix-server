# Copy to .env and fill in.

PORT=8787

# Clinica portal (event source + JWT validation via its register endpoint).
CLINICA_PORTAL_URL=https://clinica-portal.cashflohero.ai

# CouchDB — already used for HealthPlix. Include credentials in the URL or use COUCHDB_USER/PASS.
COUCHDB_URL=http://admin:password@localhost:5984
COUCHDB_DB=healthplix_credentials

# HealthPlix API the server replays the Bearer JWT against.
HEALTHPLIX_API_BASE=https://emr30-edge.healthplix.com
HEALTHPLIX_WEB_APP=https://md.healthplix.com

# Authless intake fallback (lightly protected). INTAKE_KEY must match the INTAKE_KEY constant
# baked into the courier extension's background.js. INTAKE_ALLOWED_ORIGIN is optional.
INTAKE_KEY=change-me-shared-with-extension
INTAKE_ALLOWED_ORIGIN=
